# Required. Use your OpenProject root URL, not the API path.
OPENPROJECT_BASE_URL=https://your-openproject.example.com

# Recommended. OpenProject API tokens can be passed as Bearer tokens.
OPENPROJECT_API_TOKEN=replace-with-your-api-token

# Optional alternative for OAuth2 access tokens.
# OPENPROJECT_ACCESS_TOKEN=replace-with-your-oauth-access-token

# Optional admin HTML-session credentials for customer-option management.
# Required only for list_customer_options, add_customer_option,
# and bulk_add_customer_options.
# OPENPROJECT_ADMIN_USERNAME=replace-with-your-openproject-admin-username
# OPENPROJECT_ADMIN_PASSWORD=replace-with-your-openproject-admin-password

# Optional. Defaults to the Customer custom field id used in this workspace.
# OPENPROJECT_CUSTOMER_FIELD_ID=4

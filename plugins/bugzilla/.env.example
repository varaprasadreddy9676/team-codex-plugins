# Required. Use the Bugzilla root URL, without /jsonrpc.cgi or /rest.
BUGZILLA_BASE_URL=http://your-bugzilla.example.com

# Recommended when your Bugzilla instance supports API keys.
BUGZILLA_API_TOKEN=replace-with-your-api-token

# Alternative for older installations or when API-key authentication is not enabled.
# The server logs in through JSON-RPC and keeps the short-lived session token in memory.
# BUGZILLA_USERNAME=your-bugzilla-username
# BUGZILLA_PASSWORD=replace-with-your-password

# auto selects REST when /rest/version works, otherwise JSON-RPC.
BUGZILLA_AUTH_MODE=auto
BUGZILLA_TRANSPORT=auto

# Optional. Required only for bugzilla_to_openproject after the preview is approved.
# OPENPROJECT_BASE_URL=https://your-openproject.example.com
# OPENPROJECT_API_TOKEN=replace-with-your-openproject-api-token
